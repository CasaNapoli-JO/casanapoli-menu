*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial;
}

body{
height:100vh;
background:#5a3e2b;
display:flex;
flex-direction:column;
}

.overlay{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:rgba(0,0,0,0.45);
z-index:0;
}

.header{
position:relative;
z-index:2;
display:flex;
align-items:center;
padding:30px 50px;
color:white;
}

.logo{
width:90px;
margin-right:20px;
}

.title h1{
font-size:32px;
letter-spacing:2px;
}

.title p{
font-size:14px;
margin-top:5px;
}

.italy{
width:120px;
height:6px;
margin:10px 0;
background:linear-gradient(to right,
green 33%,
white 33%,
white 66%,
red 66%);
}

.hero{
flex:1;
display:flex;
justify-content:center;
align-items:center;
position:relative;
z-index:2;
}

.emblem{
width:340px;
}
